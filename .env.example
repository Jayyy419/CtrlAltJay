# Admin Passcode — set ONE of these (the app reads these exact names).
# Prefer ADMIN_PASSCODE_HASH in production; generate it with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('your-passcode'))"
# ADMIN_PASSWORD is accepted too, as a legacy alias for ADMIN_PASSCODE — kept
# for deployments already configured with that name. New setups should use
# ADMIN_PASSCODE_HASH or ADMIN_PASSCODE instead.
ADMIN_PASSCODE_HASH=
ADMIN_PASSCODE=change_me

# Flask Configuration
SECRET_KEY=your-secret-key-here
# Set to 1 only for local HTTP development — enables the Werkzeug debugger
# and disables the Secure cookie flag. Never set this in production.
FLASK_DEBUG=0

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=true
MAIL_USE_SSL=false
